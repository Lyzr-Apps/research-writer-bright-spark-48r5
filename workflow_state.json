{
  "app_name": "Research Writer Hub",
  "pattern": "manager-subagent",
  "agents": {
    "manager": {
      "agent_id": "69c500924f851c627e46ab69",
      "name": "Research Writer Manager",
      "model": "gpt-4.1",
      "provider": "openai",
      "temperature": 0.3,
      "top_p": 1,
      "managed_agents": [
        "69c5007e1d83f69a4fdabce3",
        "69c5007e3c7ecc186a3e83c7"
      ],
      "response_schema_file": "response_schemas/research_writer_manager_response.json"
    },
    "sub_agents": [
      {
        "agent_id": "69c5007e1d83f69a4fdabce3",
        "name": "Web Research Agent",
        "model": "sonar-pro",
        "provider": "perplexity",
        "temperature": 0.3,
        "top_p": 1,
        "response_schema_file": "response_schemas/web_research_agent_response.json"
      },
      {
        "agent_id": "69c5007e3c7ecc186a3e83c7",
        "name": "Content Writer Agent",
        "model": "gpt-4.1",
        "provider": "openai",
        "temperature": 0.5,
        "top_p": 1,
        "response_schema_file": "response_schemas/content_writer_agent_response.json"
      }
    ]
  },
  "database": {
    "db_name": "app_research-writer-sharp-dock-hzdo",
    "collections": ["articles"],
    "schema": {
      "articles": {
        "fields": {
          "title": { "type": "string", "required": true },
          "topic": { "type": "string", "required": true },
          "content": { "type": "string", "required": false },
          "summary": { "type": "string", "required": false },
          "sources": { "type": "array", "items": { "title": "string", "url": "string" } },
          "sections": { "type": "array", "items": { "heading": "string", "content": "string" } },
          "word_count": { "type": "number", "required": false },
          "status": { "type": "string", "enum": ["generating", "completed", "failed"], "default": "generating" }
        }
      }
    }
  },
  "workflow": {
    "nodes": [
      { "id": "input_node", "type": "Input", "label": "User Topic Input", "nodeCategory": "input" },
      { "id": "manager_agent", "type": "Agent", "label": "Research Writer Manager", "nodeCategory": "agent" },
      { "id": "research_agent", "type": "Agent", "label": "Web Research Agent", "nodeCategory": "agent" },
      { "id": "writer_agent", "type": "Agent", "label": "Content Writer Agent", "nodeCategory": "agent" },
      { "id": "output_node", "type": "Output", "label": "Final Article Output", "nodeCategory": "end" }
    ],
    "edges": [
      { "source": "input_node", "target": "manager_agent" },
      { "source": "manager_agent", "target": "research_agent" },
      { "source": "manager_agent", "target": "writer_agent" },
      { "source": "manager_agent", "target": "output_node" }
    ]
  }
}